# Flask
SECRET_KEY=your-secret-key-here
FLASK_DEBUG=false

# Camera
CAMERA_INDEX=0

# Model
MODEL_URL=https://github.com/mohamed-suhaib-ai/Weapons-and-Knives-Detector-with-YOLOv8/releases/download/model/best.pt
CONFIDENCE_THRESHOLD=0.5

# Alerts
ALERT_COOLDOWN_SECONDS=60
RECORDING_DURATION_SECONDS=10
RECORDING_FPS=20

# Face recognition
FACE_DISTANCE_THRESHOLD=0.35

# GPS fallback coordinates
DEFAULT_LATITUDE=13.0827
DEFAULT_LONGITUDE=80.2707

# Email (Gmail SMTP)
EMAIL_USER=
EMAIL_PASS=

# Telegram
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Optional features
MOTION_DETECTION_ENABLED=true
MOTION_THRESHOLD=5000
